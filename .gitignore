# ============================================================
#  .gitignore for Disease Prediction Django + ML Project
# ============================================================

# ----------------------------------------------------------
# Python
# ----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.env

# ----------------------------------------------------------
# Virtual Environment
# ----------------------------------------------------------
venv/
.venv/
env/
.env/
ENV/

# ----------------------------------------------------------
# Django
# ----------------------------------------------------------
*.pyc
db.sqlite3
db.sqlite3-journal

# Collected static files (generated by collectstatic)
staticfiles/
static_collected/

# Media uploads (user-uploaded content — usually not versioned)
media/

# Django secret key & environment variables
.env
.env.*
!.env.example

# Django local settings override
local_settings.py

# ----------------------------------------------------------
# Machine Learning / Data Science
# ----------------------------------------------------------
# Large trained model binaries (pickle, joblib, h5, etc.)
# Uncomment below if you don't want to track them in git
# (recommended if files are >50 MB — use Git LFS instead)
# *.pkl
# *.pickle
# *.joblib
# *.h5
# *.hdf5

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/
*.ipynb

# Dataset files (usually large)
*.csv
*.xlsx
*.xls
*.json.gz
*.zip
*.tar.gz

# ----------------------------------------------------------
# IDE & Editor
# ----------------------------------------------------------
# VS Code
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Emacs swap files
*.swp
*.swo
*~

# ----------------------------------------------------------
# OS-Generated Files
# ----------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# ----------------------------------------------------------
# Logs & Debug
# ----------------------------------------------------------
*.log
*.log.*
logs/
log/
debug.log
django_debug.log

# ----------------------------------------------------------
# Coverage & Testing
# ----------------------------------------------------------
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.pytest_cache/
.tox/
nosetests.xml
test-results/

# ----------------------------------------------------------
# Build / Distribution
# ----------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/
pip-wheel-metadata/
share/python-wheels/

# ----------------------------------------------------------
# Dependency Locks (keep requirements.txt, ignore lock files)
# ----------------------------------------------------------
Pipfile.lock
poetry.lock

# ----------------------------------------------------------
# Secrets & Keys
# ----------------------------------------------------------
*.pem
*.key
*.cert
*.p12
secrets.json
secrets.yaml

# ----------------------------------------------------------
# Docker (if used later)
# ----------------------------------------------------------
*.env.docker
docker-compose.override.yml
